rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Facilities — owner has full access, all authenticated users can read (for admin views)
    match /facilities/{facilityId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == facilityId;
    }

    // Inventory — scoped to facility owner, admin can read all
    match /inventory/{facilityId}/medicines/{medId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == facilityId;
    }

    // Daily Usage Logs — scoped to facility owner, admin can read all
    match /daily_usage_logs/{facilityId}/logs/{logId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == facilityId;
    }

    // Requests — any authenticated user can read (admin needs global view), 
    // any authenticated user can create, only owner or admin can update
    match /requests/{requestId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;
      allow update: if request.auth != null;
    }

    // Alerts — readable by all authenticated, writable by system (Cloud Functions)
    match /alerts/{alertId} {
      allow read: if request.auth != null;
      allow write: if false; // Only Cloud Functions write alerts
    }
  }
}
